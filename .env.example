# Copy to .env.local and fill in from your Supabase project → Project Settings → API.
# Both values are safe to expose in the browser; the RLS policies in
# supabase/migrations are what actually protect the data.
#
# Do NOT put the Supabase *secret* key (sb_secret_...) in any NEXT_PUBLIC_ var.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Public site origin (no trailing slash) used to build absolute auth links such as
# the password-reset redirect. Pin this in production so a spoofed Host header
# can't poison the reset link. Must also be added to Supabase → Auth → URL
# Configuration → Redirect URLs (as <origin>/auth/callback). Falls back to the
# request host only outside production.
NEXT_PUBLIC_SITE_URL=https://your-app-domain.example
